import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();
        int temp = n;

        int sum = 0;
        int product = 1;

        while (temp > 0) {
            int rem = temp % 10;
            sum += rem;
            product *= rem;
            temp /= 10;
        }

        if (sum == product)
            System.out.println("Spy Number");
        else
            System.out.println("Not a Spy Number");
    }
}
