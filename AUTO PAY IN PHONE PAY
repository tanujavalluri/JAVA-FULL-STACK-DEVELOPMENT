import java.util.Scanner;

// Parent Class
class BankAccount {
    String accountHolder;
    double balance;

    // Constructor
    BankAccount(String accountHolder, double balance) {
        this.accountHolder = accountHolder;
        this.balance = balance;
    }

    // Deposit Method
    void deposit(double amount) {
        balance += amount;
        System.out.println("₹" + amount + " deposited successfully.");
    }

    // Display Balance
    void displayBalance() {
        System.out.println("Account Holder : " + accountHolder);
        System.out.println("Current Balance: ₹" + balance);
    }
}

// Child Class
class PhonePeAutoPay extends BankAccount {

    PhonePeAutoPay(String accountHolder, double balance) {
        super(accountHolder, balance);
    }

    // AutoPay Method
    void autoPay(double billAmount) {
        System.out.println("\nAutoPay Request: ₹" + billAmount);

        if (billAmount <= balance) {
            balance -= billAmount;
            System.out.println("AutoPay Successful!");
            System.out.println("Bill Paid: ₹" + billAmount);
        } else {
            System.out.println("AutoPay Failed! Insufficient Balance.");
        }
    }
}

// Main Class
public class Main {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.print("Enter Account Holder Name: ");
        String name = sc.nextLine();

        System.out.print("Enter Initial Balance: ₹");
        double balance = sc.nextDouble();

        PhonePeAutoPay user = new PhonePeAutoPay(name, balance);

        System.out.println("\n--- Banking System ---");
        user.displayBalance();

        System.out.print("\nEnter Deposit Amount: ₹");
        double deposit = sc.nextDouble();
        user.deposit(deposit);

        System.out.print("\nEnter AutoPay Bill Amount: ₹");
        double bill = sc.nextDouble();
        user.autoPay(bill);

        System.out.println("\nFinal Account Details");
        user.displayBalance();

        sc.close();
    }
}
